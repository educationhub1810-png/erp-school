# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.login

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local secrets / credential dumps (never commit)
*.local.md

# scripts/totp-qr-png.ts renders live, decodable authenticator QR codes here —
# never commit these, they're a working credential, not a screenshot.
/totp-qr/

# local Claude Code settings
.claude/settings.local.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# test artifacts
/playwright-report
/test-results
/.playwright

# dev server log
.dev.log