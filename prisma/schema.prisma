generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  PRINCIPAL
  TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
  LIBRARIAN
  TRANSPORT_MANAGER
  HR_MANAGER
  WARDEN_MANAGER
  MESS_MANAGER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ParentType {
  FATHER
  MOTHER
  GUARDIAN
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  HOLIDAY
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum PaymentMode {
  CASH
  CHEQUE
  ONLINE
  NEFT
  UPI
  CARD
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  SICK
  CASUAL
  EARNED
  MATERNITY
  PATERNITY
  UNPAID
  OTHER
}

enum NotificationType {
  SMS
  EMAIL
  PUSH
  WHATSAPP
  IN_APP
}

enum IssueStatus {
  ISSUED
  RETURNED
  OVERDUE
}

enum ExamType {
  UNIT_TEST
  MID_TERM
  FINAL
  PRACTICAL
  INTERNAL
  EXTERNAL
}

enum Grade {
  A_PLUS
  A
  B_PLUS
  B
  C_PLUS
  C
  D
  F
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum FrequencyType {
  ONE_TIME
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  ANNUALLY
}

enum RecruitmentStatus {
  OPEN
  CLOSED
  ON_HOLD
}

enum RoomType {
  SINGLE
  DOUBLE
  TRIPLE
  DORMITORY
}

enum BugStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum BugPriority {
  LOW
  MEDIUM
  HIGH
}

// ─────────────────────────────────────────────
// SCHOOLS & ACADEMIC YEAR
// ─────────────────────────────────────────────

model School {
  id                 String   @id @default(cuid())
  name               String
  code               String   @unique
  logo               String?
  regNumber          String?
  affiliationNumber  String?
  principalName      String?
  establishedDate    DateTime?
  email              String?
  phone              String?
  address            String?
  city               String?
  state              String?
  country            String   @default("India")
  timezone           String   @default("Asia/Kolkata")
  currency           String   @default("INR")
  language           String   @default("en")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  academicYears      AcademicYear[]
  users              User[]
  classes            Class[]
  subjects           Subject[]
  students           Student[]
  teachers           Teacher[]
  parentProfiles     ParentProfile[]
  staff              Staff[]
  announcements      Announcement[]
  notifications      Notification[]
  feeStructures      FeeStructure[]
  libraryBooks       LibraryBook[]
  transportRoutes    TransportRoute[]
  transportSlabs     TransportDistanceSlab[]
  hostelRooms        HostelRoom[]
  lmsCourses         LmsCourse[]
  exams              Exam[]
  recruitments       Recruitment[]
  timetables         Timetable[]
  homeworks          Homework[]
  attendance         Attendance[]
  staffAttendance    StaffAttendance[]
  leaveRequests      LeaveRequest[]
  payrolls           Payroll[]
  expenses           Expense[]
  chatMessages       ChatMessage[]
  bugTickets         BugTicket[]

  @@map("schools")
}

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  school     School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  attendance Attendance[]
  exams      Exam[]
  feeStructures FeeStructure[]

  @@map("academic_years")
}

// ─────────────────────────────────────────────
// USERS (all roles)
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  schoolId     String?
  name         String
  email        String?  @unique
  mobile       String?
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school            School?      @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  teacher           Teacher?
  staff             Staff?
  student           Student?
  parentProfile     ParentProfile?
  accounts          Account[]
  sessions          Session[]
  sentMessages      ChatMessage[] @relation("SentMessages")
  receivedMessages  ChatMessage[] @relation("ReceivedMessages")
  leaveRequests     LeaveRequest[]
  approvedLeaves    LeaveRequest[] @relation("ApprovedLeaves")
  announcements     Announcement[]
  reportedBugs      BugTicket[]   @relation("ReportedBugs")
  loginOtps         LoginOtp[]

  @@map("users")
}

// Per-role two-factor policy, editable by Super Admin at
// /super-admin/settings. One row per role that has been explicitly configured;
// roles with no row fall back to the built-in default (TWO_FACTOR_ROLES). See
// lib/two-factor-policy.ts.
model TwoFactorPolicy {
  role      String   @id // an AppRole value
  required  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("two_factor_policies")
}

// Email-OTP two-factor challenges. One row per code issued during a login
// attempt for a role that requires 2FA (see lib/roles.ts requiresTwoFactor).
// The code itself is never stored — only a bcrypt hash — and rows are short-
// lived (OTP_TTL_MS) and single-use (consumedAt), with an attempt cap.
model LoginOtp {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String // bcrypt hash of the 6-digit code
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("login_otps")
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// CLASSES & SECTIONS & SUBJECTS
// ─────────────────────────────────────────────

model Class {
  id             String  @id @default(cuid())
  schoolId       String
  name           String
  capacity       Int     @default(40)
  classTeacherId String?
  createdAt      DateTime @default(now())

  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sections     Section[]
  subjects     Subject[]
  students     Student[]
  timetables   Timetable[]
  homeworks    Homework[]
  exams        Exam[]
  feeStructures FeeStructure[]
  lmsCourses   LmsCourse[]

  @@map("classes")
}

model Section {
  id       String @id @default(cuid())
  classId  String
  name     String
  capacity Int    @default(40)

  class       Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  students    Student[]
  timetables  Timetable[]
  homeworks   Homework[]

  @@map("sections")
}

model Subject {
  id          String @id @default(cuid())
  schoolId    String
  classId     String
  name        String
  code        String?
  passMarks   Int?
  totalMarks  Int    @default(100)
  teacherId   String?
  createdAt   DateTime @default(now())

  school       School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class        Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher      Teacher?       @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  timetables   Timetable[]
  homeworks    Homework[]
  examSchedules ExamSchedule[]

  @@map("subjects")
}

// ─────────────────────────────────────────────
// STUDENTS
// ─────────────────────────────────────────────

model Student {
  id               String   @id @default(cuid())
  schoolId         String
  userId           String   @unique
  studentCode      String   @unique
  rollNumber       String?
  firstName        String
  middleName       String?
  lastName         String
  gender           Gender
  dob              DateTime?
  bloodGroup       String?
  category         String?
  religion         String?
  aadhaar          String?
  photoUrl         String?
  classId          String
  sectionId        String?
  house            String?
  transportRequired Boolean @default(false)
  hostelRequired   Boolean  @default(false)
  medicalNotes     String?
  admissionDate    DateTime @default(now())
  rfidNumber       String?
  previousSchool   String?
  addressLine1     String?
  addressLine2     String?
  zipCode          String?
  city             String?
  state            String?
  country          String?
  isAlumni         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  school          School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  class           Class              @relation(fields: [classId], references: [id])
  section         Section?           @relation(fields: [sectionId], references: [id])
  parent          Parent?
  parentProfiles  ParentProfile[]
  documents       Document[]
  attendance      Attendance[]
  feePayments     FeePayment[]
  examResults     ExamResult[]
  scholarships    Scholarship[]
  libraryIssues   LibraryIssue[]
  transportAssign TransportStudent?
  hostelAllocation HostelAllocation?
  homeworkSubmissions HomeworkSubmission[]

  @@map("students")
}

model Parent {
  id                  String  @id @default(cuid())
  schoolId            String
  studentId           String  @unique
  fatherName          String?
  fatherMobile        String?
  fatherEmail         String?
  fatherOccupation    String?
  motherName          String?
  motherMobile        String?
  motherEmail         String?
  motherOccupation    String?
  guardianName        String?
  guardianMobile      String?
  guardianRelation    String?
  address             String?
  createdAt           DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("parents")
}

model ParentProfile {
  id          String     @id @default(cuid())
  userId      String     @unique
  schoolId    String
  studentId   String?
  parentCode  String     @unique
  parentType  ParentType
  firstName   String
  middleName  String?
  lastName    String
  gender      Gender
  dob         DateTime?
  maritalStatus MaritalStatus?
  nationality String?
  aadhaar     String?
  pan         String?
  address     String?
  createdAt   DateTime   @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school  School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("parent_profiles")
}

model Document {
  id          String   @id @default(cuid())
  schoolId    String
  entityType  String
  entityId    String
  docType     String
  fileUrl     String
  uploadedAt  DateTime @default(now())

  student Student? @relation(fields: [entityId], references: [id])

  @@map("documents")
}

// ─────────────────────────────────────────────
// TEACHERS & STAFF
// ─────────────────────────────────────────────

model Teacher {
  id               String   @id @default(cuid())
  schoolId         String
  userId           String   @unique
  employeeId       String
  gender           Gender?
  dob              DateTime?
  qualification    String?
  experienceYears  Int?
  specialization   String?
  joiningDate      DateTime?
  salary           Float?
  bankName         String?
  accountNumber    String?
  ifscCode         String?
  pan              String?
  aadhaar          String?
  photoUrl         String?
  resumeUrl        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  school     School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  timetables Timetable[]
  payrolls   Payroll[]
  subjects   Subject[]

  @@map("teachers")
}

model Staff {
  id          String   @id @default(cuid())
  schoolId    String
  userId      String   @unique
  employeeId  String
  department  String?
  designation String?
  dob         DateTime?
  joiningDate DateTime?
  salary      Float?
  bankName    String?
  accountNumber String?
  ifscCode    String?
  pan         String?
  aadhaar     String?
  qualification   String?
  experienceYears Int?
  licenseNumber   String?
  vehicleNumber   String?
  assignedBlock   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  school          School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staffAttendance StaffAttendance[]
  payrolls        Payroll[]
  hostelRooms     HostelRoom[]

  @@map("staff")
}

// ─────────────────────────────────────────────
// TIMETABLE
// ─────────────────────────────────────────────

model Timetable {
  id         String @id @default(cuid())
  schoolId   String
  classId    String
  sectionId  String?
  subjectId  String
  teacherId  String?
  dayOfWeek  Int
  startTime  String
  endTime    String

  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  section   Section? @relation(fields: [sectionId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  @@map("timetables")
}

// ─────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────

model Attendance {
  id             String           @id @default(cuid())
  schoolId       String
  studentId      String
  academicYearId String?
  date           DateTime         @db.Date
  status         AttendanceStatus @default(PRESENT)
  checkIn        DateTime?
  checkOut       DateTime?
  remarks        String?

  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id])

  @@unique([studentId, date])
  @@map("attendance")
}

model StaffAttendance {
  id       String           @id @default(cuid())
  schoolId String
  staffId  String
  date     DateTime         @db.Date
  status   AttendanceStatus @default(PRESENT)
  checkIn  DateTime?
  checkOut DateTime?

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@map("staff_attendance")
}

// ─────────────────────────────────────────────
// EXAMS & RESULTS
// ─────────────────────────────────────────────

model Exam {
  id             String   @id @default(cuid())
  schoolId       String
  academicYearId String?
  classId        String
  name           String
  examType       ExamType @default(UNIT_TEST)
  startDate      DateTime?
  endDate        DateTime?
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())

  school       School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear?  @relation(fields: [academicYearId], references: [id])
  class        Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  schedules    ExamSchedule[]
  results      ExamResult[]

  @@map("exams")
}

model ExamSchedule {
  id         String   @id @default(cuid())
  examId     String
  subjectId  String
  date       DateTime?
  startTime  String?
  endTime    String?
  totalMarks Int      @default(100)
  passMarks  Int      @default(35)

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  results ExamResult[]

  @@map("exam_schedules")
}

model ExamResult {
  id             String  @id @default(cuid())
  schoolId       String
  examId         String
  examScheduleId String?
  studentId      String
  marksObtained  Float?
  grade          String?
  gpa            Float?
  rank           Int?
  remarks        String?
  isAbsent       Boolean @default(false)

  exam         Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  examSchedule ExamSchedule? @relation(fields: [examScheduleId], references: [id])
  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examScheduleId, studentId])
  @@map("exam_results")
}

// ─────────────────────────────────────────────
// FEES & FINANCE
// ─────────────────────────────────────────────

model FeeStructure {
  id             String        @id @default(cuid())
  schoolId       String
  classId        String?
  academicYearId String?
  feeType        String
  amount         Float
  dueDate        DateTime?
  frequency      FrequencyType @default(ONE_TIME)
  monthlyDueDay  Int?          // day-of-month (1–31) for MONTHLY structures
  installments   Json?         // [{period:"Q1 Apr–Jun",dueDate:"2025-06-30"},…] for QUARTERLY/HALF_YEARLY
  description    String?
  createdAt      DateTime      @default(now())

  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class        Class?        @relation(fields: [classId], references: [id])
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id])
  payments     FeePayment[]

  @@map("fee_structures")
}

model FeePayment {
  id              String        @id @default(cuid())
  schoolId        String
  studentId       String
  feeStructureId  String
  amountPaid      Float
  paymentDate     DateTime      @default(now())
  receiptNumber   String        @unique
  paymentMode     PaymentMode   @default(CASH)
  transactionId   String?
  status          PaymentStatus @default(PAID)
  remarks         String?
  periodLabel     String?       // e.g. "January 2025", "Q2 Jul–Sep 2025", "Apr–Sep 2025"

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)

  @@map("fee_payments")
}

model Scholarship {
  id            String       @id @default(cuid())
  schoolId      String
  studentId     String
  name          String
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Float
  validFrom     DateTime?
  validTo       DateTime?
  createdAt     DateTime     @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("scholarships")
}

model Expense {
  id          String   @id @default(cuid())
  schoolId    String
  title       String
  amount      Float
  category    String
  date        DateTime @default(now())
  description String?
  receiptUrl  String?

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

// ─────────────────────────────────────────────
// LIBRARY
// ─────────────────────────────────────────────

model LibraryBook {
  id              String @id @default(cuid())
  schoolId        String
  title           String
  isbn            String?
  author          String?
  publisher       String?
  edition         String?
  category        String?
  rackNumber      String?
  totalCopies     Int    @default(1)
  availableCopies Int    @default(1)
  createdAt       DateTime @default(now())

  school School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  issues LibraryIssue[]

  @@map("library_books")
}

model LibraryIssue {
  id         String      @id @default(cuid())
  schoolId   String
  bookId     String
  studentId  String
  issueDate  DateTime    @default(now())
  dueDate    DateTime
  returnDate DateTime?
  fineAmount Float?      @default(0)
  status     IssueStatus @default(ISSUED)

  book    LibraryBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  student Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("library_issues")
}

// ─────────────────────────────────────────────
// TRANSPORT
// ─────────────────────────────────────────────

model TransportRoute {
  id           String @id @default(cuid())
  schoolId     String
  routeName    String
  vehicleNumber String?
  driverName   String?
  driverMobile String?
  gpsDeviceId  String?
  capacity     Int?
  createdAt    DateTime @default(now())

  school   School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students TransportStudent[]

  @@map("transport_routes")
}

model TransportStudent {
  id         String  @id @default(cuid())
  schoolId   String
  studentId  String  @unique
  routeId    String
  slabId     String?
  stopName   String?
  distanceKm Float?
  feeAmount  Float?

  student Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  route   TransportRoute         @relation(fields: [routeId], references: [id], onDelete: Cascade)
  slab    TransportDistanceSlab? @relation(fields: [slabId], references: [id])

  @@map("transport_students")
}

model TransportDistanceSlab {
  id        String   @id @default(cuid())
  schoolId  String
  label     String
  fromKm    Float
  toKm      Float?
  amount    Float
  createdAt DateTime @default(now())

  school   School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students TransportStudent[]

  @@map("transport_distance_slabs")
}

// ─────────────────────────────────────────────
// HOSTEL
// ─────────────────────────────────────────────

model HostelRoom {
  id         String   @id @default(cuid())
  schoolId   String
  roomNumber String
  floor      String?
  capacity   Int      @default(2)
  roomType   RoomType @default(DOUBLE)
  wardenId   String?
  createdAt  DateTime @default(now())

  school      School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  warden      Staff?             @relation(fields: [wardenId], references: [id])
  allocations HostelAllocation[]

  @@map("hostel_rooms")
}

model HostelAllocation {
  id         String   @id @default(cuid())
  schoolId   String
  roomId     String
  studentId  String   @unique
  bedNumber  String?
  fromDate   DateTime @default(now())
  toDate     DateTime?
  feeAmount  Float?

  room    HostelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  student Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("hostel_allocations")
}

// ─────────────────────────────────────────────
// LMS
// ─────────────────────────────────────────────

model LmsCourse {
  id            String       @id @default(cuid())
  schoolId      String
  classId       String?
  title         String
  description   String?
  teacherId     String?
  durationHours Int?
  status        CourseStatus @default(DRAFT)
  createdAt     DateTime     @default(now())

  school   School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class    Class?       @relation(fields: [classId], references: [id])
  chapters LmsChapter[]

  @@map("lms_courses")
}

model LmsChapter {
  id         String  @id @default(cuid())
  courseId   String
  title      String
  videoUrl   String?
  notesUrl   String?
  order      Int     @default(0)
  duration   Int?

  course       LmsCourse            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  assignments  LmsAssignment[]

  @@map("lms_chapters")
}

model LmsAssignment {
  id          String   @id @default(cuid())
  chapterId   String
  title       String
  description String?
  dueDate     DateTime?
  maxMarks    Int      @default(100)
  createdAt   DateTime @default(now())

  chapter     LmsChapter           @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  submissions LmsSubmission[]

  @@map("lms_assignments")
}

model LmsSubmission {
  id           String   @id @default(cuid())
  assignmentId String
  studentId    String
  fileUrl      String?
  submittedAt  DateTime @default(now())
  marks        Float?
  remarks      String?

  assignment LmsAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@map("lms_submissions")
}

// ─────────────────────────────────────────────
// HOMEWORK
// ─────────────────────────────────────────────

model Homework {
  id            String   @id @default(cuid())
  schoolId      String
  subjectId     String?
  classId       String
  sectionId     String?
  teacherId     String?
  title         String
  description   String?
  dueDate       DateTime?
  attachmentUrl String?
  createdAt     DateTime @default(now())

  school      School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class       Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  section     Section?             @relation(fields: [sectionId], references: [id])
  subject     Subject?             @relation(fields: [subjectId], references: [id])
  submissions HomeworkSubmission[]

  @@map("homeworks")
}

model HomeworkSubmission {
  id          String   @id @default(cuid())
  homeworkId  String
  studentId   String
  submittedAt DateTime @default(now())
  fileUrl     String?
  marks       Float?
  remarks     String?

  homework Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([homeworkId, studentId])
  @@map("homework_submissions")
}

// ─────────────────────────────────────────────
// COMMUNICATION
// ─────────────────────────────────────────────

model Announcement {
  id            String   @id @default(cuid())
  schoolId      String
  title         String
  body          String
  createdById   String
  targetRoles   Role[]
  attachmentUrl String?
  createdAt     DateTime @default(now())

  school    School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdById], references: [id])

  @@map("announcements")
}

model Notification {
  id       String           @id @default(cuid())
  schoolId String
  title    String
  body     String
  type     NotificationType @default(IN_APP)
  targetRole Role?
  sentAt   DateTime         @default(now())
  status   String           @default("SENT")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ChatMessage {
  id         String   @id @default(cuid())
  schoolId   String
  senderId   String
  receiverId String
  message    String
  sentAt     DateTime @default(now())
  readAt     DateTime?

  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sender   User   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User   @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

// ─────────────────────────────────────────────
// LEAVE & PAYROLL & HR
// ─────────────────────────────────────────────

model LeaveRequest {
  id          String      @id @default(cuid())
  schoolId    String
  userId      String
  fromDate    DateTime
  toDate      DateTime
  leaveType   LeaveType   @default(CASUAL)
  reason      String?
  status      LeaveStatus @default(PENDING)
  approvedById String?
  approvedAt  DateTime?
  createdAt   DateTime    @default(now())

  school     School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy User?  @relation("ApprovedLeaves", fields: [approvedById], references: [id])

  @@map("leave_requests")
}

model Payroll {
  id          String  @id @default(cuid())
  schoolId    String
  staffId     String?
  teacherId   String?
  month       Int
  year        Int
  basic       Float   @default(0)
  allowances  Float   @default(0)
  deductions  Float   @default(0)
  bonus       Float   @default(0)
  netSalary   Float   @default(0)
  status      PaymentStatus @default(PENDING)
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  school  School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staff   Staff?   @relation(fields: [staffId], references: [id])
  teacher Teacher? @relation(fields: [teacherId], references: [id])

  @@map("payrolls")
}

model Recruitment {
  id               String            @id @default(cuid())
  schoolId         String
  jobTitle         String
  vacancies        Int               @default(1)
  experienceRequired String?
  salaryRange      String?
  description      String?
  postedAt         DateTime          @default(now())
  status           RecruitmentStatus @default(OPEN)

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("recruitments")
}

// ─────────────────────────────────────────────
// BUG TRACKER (JIRA-style board)
// ─────────────────────────────────────────────

model BugTicket {
  id             String      @id @default(cuid())
  schoolId       String?
  reporterId     String
  title          String
  description    String
  whatNotWorking String
  whatExpected   String
  screenshotUrl  String?
  status         BugStatus   @default(OPEN)
  priority       BugPriority @default(MEDIUM)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  reporter User    @relation("ReportedBugs", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([status])
  @@map("bug_tickets")
}

// ─────────────────────────────────────────────
// SECURITY AUDIT LOG (append-only)
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String?
  schoolId   String?
  action     String
  targetType String?
  targetId   String?
  metadata   String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
